<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Chat" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Contact (link/QR)" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Send File" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Voice Message" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Audio Call" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Video Call" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Privacy Settings" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Network Settings" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Panic Wipe - Step 1" android:textColor="#E7E9EA" />
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Panic Wipe - Step 2 (final)" android:textColor="#E7E9EA" />
</LinearLayout>